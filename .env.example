# --- LLM provider (ADR-0003: swappable via Vercel AI SDK) -------------------
# Set one (or both) keys. With no LLM_PROVIDER set, the first configured key
# wins: groq → google. With no keys at all, the app serves a built-in mock
# recipe so the UI stays fully testable.
GROQ_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Optional explicit overrides:
# LLM_PROVIDER=groq | google | mock
# LLM_MODEL=openai/gpt-oss-120b       (groq default; must support json_schema —
#                                       see console.groq.com/docs/structured-outputs)
# LLM_MODEL=gemini-2.5-flash          (google default)

# --- Proxy guardrails (ADR-0002) ---------------------------------------------
GENERATIONS_PER_10MIN_PER_IP=10
DAILY_GENERATION_CAP=100
